# Copy to `.env` and fill in real values. Loaded automatically by env_loader.py.
# NEVER commit the populated .env (it is git-ignored).

# ---- Pacifica (Solana) ----
# Public key of the main account that holds the funds.
PACIFICA_ACCOUNT=
# Base58-encoded private key of the *agent* wallet authorised to trade for ACCOUNT.
PACIFICA_AGENT_PRIVATE_KEY=
# REST API key issued by Pacifica.
PACIFICA_API_KEY=

# ---- Extended / X10 (Starknet) ----
EXTENDED_API_KEY=
# Stark keys must be 0x-prefixed hex strings.
EXTENDED_PRIVATE_KEY=
EXTENDED_PUBLIC_KEY=
EXTENDED_VAULT_ID=

# ---- Extended optional overrides (leave blank for mainnet defaults) ----
# EXTENDED_BASE_URL=
# EXTENDED_STREAM_URL=
# EXTENDED_USER_AGENT=extended-pocket-bot/1.0
